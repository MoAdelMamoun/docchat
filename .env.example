# DocChat configuration — ALL OPTIONAL.
# The demo runs with ZERO config: no API key, no network, keyless retrieval.
# Copy this to `.env` only if you want the FULL version (real LLM answers).

# --- FULL version: enable real LLM answers ------------------------------------
# Set ONE of these to switch from the keyless extractive demo to LLM-generated
# answers grounded in the retrieved context. Empty (default) → keyless demo.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional model overrides for the full version.
DOCCHAT_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
DOCCHAT_OPENAI_MODEL=gpt-4o-mini

# --- Runtime (sensible defaults; the demo needs none of these) ----------------
# Where the SQLite index database lives (defaults to ./docchat_demo.db).
DOCCHAT_DB_PATH=
# Where uploaded PDFs are stored (defaults to ./uploads).
DOCCHAT_UPLOAD_DIR=
